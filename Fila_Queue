from collections import deque # Double ended queue

# Filas (Queue) com Classe(Objeto) sem prioridade
class Fila:
    def __init__(self):
        self.itens = deque()

    def is_empty(self):
        return len(self.itens) == 0
    
    def enqueue(self, item):
        self.itens.append(item)  # Entra no final da fila

    def dequeue(self):
        if not self.is_empty():
            return self.itens.popleft()  # Remove do inicio da fila
        raise IndexError("A fila está vazia!")

    def __str__(self):
        return str(list(self.itens))
    
# Criação do objeto Fila
fila_classe = Fila()   # Instaciar objeto da classe Fila
print(fila_classe.is_empty())

fila_classe.enqueue("Ana")
fila_classe.enqueue("Bernando")
fila_classe.enqueue("Carlos")

print("Fila:",fila_classe)
print("Atendido:",fila_classe.dequeue())
print("Fila atualizada:",fila_classe)
